# Copy this file to airflow/.env and fill in your values.
# Never commit airflow/.env — it contains credentials.

# Redshift credentials (same vars used by dbt/profiles.yml)
REDSHIFT_HOST=analytics.725960317874.eu-west-2.redshift-serverless.amazonaws.com
REDSHIFT_USER=admin
DBT_PASSWORD=your_password

# Airflow fernet key — used to encrypt the Redshift connection password in the metadata DB.
# Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Never change this after first run — rotating it decrypts existing stored passwords.
AIRFLOW__CORE__FERNET_KEY=

# Slack webhook for failure alerts (optional — silently skipped if not set)
SLACK_WEBHOOK_URL=
